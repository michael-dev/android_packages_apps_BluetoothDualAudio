<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher icon foreground: two overlapping headphones in white.
  108dp × 108dp canvas with 72dp × 72dp safe zone (content centered in
  the middle 2/3). Paths are pure fill — no strokes — so the icon
  renders consistently across DPIs and adaptive-icon mask shapes.
-->
